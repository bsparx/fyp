generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  role                Role                 @default(PATIENT)
  clerkId             String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  doctorProfile       DoctorProfile?
  documents           Document[]
  medicalReports      MedicalReport[]
  medicalReportValues MedicalReportValue[]
  NoteTemplate        NoteTemplate[]
  patientProfile      PatientProfile?
}

model Document {
  id              String           @id @default(cuid())
  title           String
  content         String
  pdfUrl          String?
  type            DocumentType     @default(RAG)
  ragSubtype      RagSubtype?
  patientDataType PatientDataType?
  isIngested      Boolean          @default(false)
  userId          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User?            @relation(fields: [userId], references: [id])
  medicalReports  MedicalReport[]
  parentChunks    ParentChunk[]
  ragChunks       RagChunk[]

  @@index([userId, type, createdAt(sort: Desc)])
}

model ParentChunk {
  id          String     @id @default(cuid())
  documentId  String
  parentIndex Int
  parentText  String
  createdAt   DateTime   @default(now())
  document    Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  ragChunks   RagChunk[]

  @@unique([documentId, parentIndex])
}

model RagChunk {
  id            String      @id @default(cuid())
  documentId    String
  parentChunkId String
  chunkIndex    Int
  chunkText     String
  pineconeId    String      @unique
  createdAt     DateTime    @default(now())
  document      Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  parentChunk   ParentChunk @relation(fields: [parentChunkId], references: [id], onDelete: Cascade)
}

model MedicalReport {
  id            String               @id @default(cuid())
  documentId    String
  markdown      String?
  reportURL     String?
  reportDate    DateTime?
  hospitalName  String?
  userId        String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  conclusion    String?
  fidelityScore Float?
  passed        Boolean?             @default(false)
  extractedJson Json?
  document      Document             @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportValues  MedicalReportValue[]
}

model MedicalReportValue {
  id             String        @id @default(cuid())
  reportId       String
  userId         String
  key            String
  value          String
  unit           String?
  createdAt      DateTime      @default(now())
  keyNormalized  String?
  observedAt     DateTime?
  sequence       Int?
  unitNormalized String?
  valueNumeric   Float?
  report         MedicalReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([key])
  @@index([userId])
  @@index([keyNormalized])
  @@index([userId, keyNormalized])
  @@index([userId, keyNormalized, observedAt])
  @@index([reportId, keyNormalized])
}

model DoctorProfile {
  id             String         @id @default(uuid())
  userId         String         @unique
  specialization String
  appointments   Appointment[]
  user           User           @relation(fields: [userId], references: [id])
  prescriptions  Prescription[]
}

model PatientProfile {
  id               String            @id @default(uuid())
  userId           String            @unique
  phone            String?
  address          String?
  aiSummary        String?
  allergies        String?
  bloodType        String?
  conditions       String?
  dateOfBirth      DateTime?
  emergencyContact String?
  gender           String?
  height           String?
  weight           String?
  appointments     Appointment[]
  healthMetrics    HealthMetric[]
  notes            PatientNote[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders        PatientReminder[]
  prescriptions    Prescription[]
}

model Prescription {
  id           String         @id @default(uuid())
  name         String
  dosage       String
  frequency    String
  startDate    DateTime
  endDate      DateTime?
  status       String         @default("ACTIVE")
  prescribedBy String?
  patientId    String
  doctorId     String?
  doctor       DoctorProfile? @relation(fields: [doctorId], references: [id])
  patient      PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model HealthMetric {
  id        String         @id @default(uuid())
  type      String
  value     String
  unit      String?
  trend     String?
  status    String?
  date      DateTime       @default(now())
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model PatientNote {
  id        String         @id @default(uuid())
  title     String
  content   String
  tags      String?
  date      DateTime       @default(now())
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model PatientReminder {
  id          String         @id @default(uuid())
  text        String
  date        DateTime       @default(now())
  isCompleted Boolean        @default(false)
  patientId   String
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Appointment {
  id           String            @id @default(uuid())
  date         DateTime
  status       AppointmentStatus @default(PENDING)
  reason       String?
  doctorId     String?
  patientId    String?
  notes        String?
  aiStatus     String?
  createdAt    DateTime          @default(now())
  recordingUrl String?
  soapNote     Json?
  soapNoteUrl  String?
  transcript   Json?
  updatedAt    DateTime          @updatedAt
  doctor       DoctorProfile?    @relation(fields: [doctorId], references: [id])
  patient      PatientProfile?   @relation(fields: [patientId], references: [id])
}

model NoteTemplate {
  id                String              @id
  slug              String?             @unique
  name              String
  description       String
  source            NoteTemplateSource  @default(PERSONAL)
  isActive          Boolean             @default(true)
  headerFooterStyle HeaderFooterStyle   @default(DEFAULT)
  headerTextAlign   HeaderTextAlign     @default(CENTER)
  promptDirectives  String?
  profileContext    Json
  header            String
  footer            String
  normalization     Json?
  userId            String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  User              User?               @relation(fields: [userId], references: [id])
  NoteTemplateField NoteTemplateField[]

  @@index([source])
  @@index([userId, source])
}

model NoteTemplateField {
  id             String                     @id
  templateId     String
  fieldOrder     Int
  key            String
  label          String
  type           NoteTemplateFieldType      @default(STRING)
  required       Boolean                    @default(false)
  guidance       String?
  hint           String?
  fallbackPolicy NoteTemplateFallbackPolicy @default(EMPTY)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime
  NoteTemplate   NoteTemplate               @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, fieldOrder])
  @@unique([templateId, key])
  @@index([templateId, fieldOrder])
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
}

enum DocumentType {
  RAG
  PATIENT
}

enum RagSubtype {
  MEDICINE
  DISEASE
}

enum PatientDataType {
  REPORT
  COMMENT
}

enum AppointmentStatus {
  UNLINKED
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum HeaderFooterStyle {
  DEFAULT
}

enum HeaderTextAlign {
  LEFT
  CENTER
  RIGHT
}

enum NoteTemplateFallbackPolicy {
  EMPTY
  NOT_DOCUMENTED
  OMIT_IF_OPTIONAL
}

enum NoteTemplateFieldType {
  STRING
  NUMBER
  BOOLEAN
}

enum NoteTemplateSource {
  LIBRARY
  PERSONAL
}
